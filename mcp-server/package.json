{
  "name": "lightbenders-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP bridge between scanner web app and ERPNext warehouse inventory",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "mcp": "tsx src/index.ts --stdio",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
